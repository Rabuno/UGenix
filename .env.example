# ==========================================
# UGENIX UNIFIED ENVIRONMENT VARIABLES
# ==========================================
# Use this file for local development.
# Do NOT commit sensitive values to version control.

# ------------------------------------------
# FRONTEND VARIABLES
# ------------------------------------------
# The base URL of the API (Default local port: 5039)
VITE_API_BASE_URL=http://localhost:5039/api
VITE_API_VERSION=v1
# VietMap API Key (Frontend)
VITE_VIETMAP_API_KEY=your_vietmap_api_key_here

# ------------------------------------------
# BACKEND VARIABLES
# ------------------------------------------

# [Database]
ConnectionStrings__Database=Host=localhost;Database=ugenix_db;Username=postgres;Password=password
ConnectionStrings__Redis=localhost:6379

# [JWT Identity]
Jwt__Issuer=UGenix.API
Jwt__Audience=UGenix.Frontend
Jwt__Secret=your_min_32_character_secret_key_here
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# [Cloudinary]
Cloudinary__CloudName=your_cloud_name_here
Cloudinary__ApiKey=your_api_key_here
Cloudinary__ApiSecret=your_api_secret_here

# [Google Auth]
GoogleAuth__ClientId=your_google_client_id_here

# [Mail Configuration]
Mail__Host=smtp.gmail.com
Mail__Port=587
Mail__Mail=noreply@example.com
Mail__Password=your_app_password
Mail__DisplayName=UGenix Platform

# [Logging & Observability]
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Observability__OtlpEndpoint=http://localhost:4317
Observability__SeqUrl=http://localhost:5341
