# Cloudinary Configuration
CloudinaryOptions__ApiKey=your_api_key_here
CloudinaryOptions__ApiSecret=your_api_secret_here
CloudinaryOptions__CloudName=your_cloud_name_here

# PostgreSQL Configuration (Supabase or Local)
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.example.supabase.co
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_USER=postgres
POSTGRES_URL=postgres://user:password@host:port/database

# Supabase Configuration
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# Internal Identity Configuration
JwtOptions__Issuer=UGemPlatform
JwtOptions__Audience=UGemApp
JwtOptions__ExpireMinutes=120
JwtOptions__ActiveKeyId=k1
JwtOptions__ActiveSecretKey=your_min_32_character_secret_key_here
# Rotation Example:
# JwtOptions__ValidationKeys__k0=your_previous_secret_key_here

# Infrastructure
REDIS_URL=localhost:6379

# Logging & Observability
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Observability__OtlpEndpoint=http://localhost:4317
Observability__SeqUrl=http://localhost:5341

# Mail Configuration
MailOptions__Host=smtp.gmail.com
MailOptions__Port=587
MailOptions__Mail=noreply@example.com
MailOptions__Password=your_app_password
MailOptions__DisplayName=UGem Platform
